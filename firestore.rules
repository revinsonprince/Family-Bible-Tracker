rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // GLOBAL SAFETY NET
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // PRIMITIVE HELPERS (Phase 3)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // MASTER GATES (Pillar 1)
    // ===============================================================
    
    // Checks if the document exists in the members collection for the current user
    function getMemberDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function isMember(groupId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/groups/$(groupId)).data.adminUid == request.auth.uid
      );
    }

    function isApprovedMember(groupId) {
      return isMember(groupId) && (
        getMemberDoc(groupId).data.status == 'approved' ||
        get(/databases/$(database)/documents/groups/$(groupId)).data.adminUid == request.auth.uid
      );
    }

    function isGroupAdmin(groupId) {
      return isMember(groupId) && (
        getMemberDoc(groupId).data.role == 'admin' ||
        get(/databases/$(database)/documents/groups/$(groupId)).data.adminUid == request.auth.uid
      ) && (
        getMemberDoc(groupId).data.status == 'approved' ||
        get(/databases/$(database)/documents/groups/$(groupId)).data.adminUid == request.auth.uid
      );
    }

    // ===============================================================
    // VALIDATION BLUEPRINTS (Pillar 2)
    // ===============================================================
    
    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'adminUid', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.adminUid == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidReminderSettings(data) {
      return data.keys().hasAll(['enabled', 'frequency', 'time']) &&
             data.enabled is bool &&
             data.frequency in ['daily', 'weekly'] &&
             data.time is string && data.time.matches('^[0-9]{2}:[0-9]{2}$') &&
             (!('lastNudgeAt' in data) || data.lastNudgeAt == null || data.lastNudgeAt is timestamp);
    }

    function isValidMember(data) {
      return data.keys().hasAll(['displayName', 'role', 'status', 'joinedAt']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.role in ['admin', 'member'] &&
             data.status in ['pending', 'approved'] &&
             (!('lastReadAt' in data) || data.lastReadAt == null || data.lastReadAt is timestamp) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 120000)) && // Base64 limit
             (!('reminderSettings' in data) || isValidReminderSettings(data.reminderSettings));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['memberUid', 'memberName', 'book', 'chapter', 'readAt', 'confirmedByUid', 'confirmerName']) &&
             data.memberUid == request.auth.uid &&
             data.memberName is string &&
             data.book is string &&
             data.chapter is number && data.chapter >= 1 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000)) &&
             data.readAt == request.time &&
             data.confirmedByUid == null &&
             data.confirmerName == null;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['memberUid', 'memberName', 'memberPhoto', 'text', 'createdAt']) &&
             data.memberUid == request.auth.uid &&
             data.memberName is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // RESOURCE RULES
    // ===============================================================

    match /groups/{groupId} {
      allow get: if isSignedIn() && isValidId(groupId);
      allow list: if isSignedIn(); // Users find groups by code
      
      allow create: if isVerified() && isValidId(groupId) && isValidGroup(incoming());
      allow update: if isGroupAdmin(groupId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
        incoming().name is string && incoming().name.size() > 0
      );

      // Members Subcollection
      match /members/{memberUid} {
        // OWN Profile: Can always read if signed in (prevents race condition on join)
        // Group Profile: Can read if already a member
        allow get: if isSignedIn() && isValidId(groupId) && isValidId(memberUid) && (
          memberUid == request.auth.uid || isMember(groupId)
        );
        
        // List members: Only for group members (Pillar 8 sync)
        allow list: if isMember(groupId);

        allow create: if isVerified() && memberUid == request.auth.uid && (
          // Admin creator joining
          (get(/databases/$(database)/documents/groups/$(groupId)).data.adminUid == request.auth.uid && 
           incoming().role == 'admin' && 
           incoming().status == 'approved') ||
          // Regular user joining
          (incoming().role == 'member' && 
           incoming().status == 'pending')
        ) && isValidMember(incoming()) && incoming().joinedAt == request.time;

        allow update: if isVerified() && (
          // Admin update: Can approve or change roles
          (isGroupAdmin(groupId) && 
           incoming().diff(existing()).affectedKeys().hasAny(['status', 'role'])) ||
          // User update: Can update photo, name, or settings
          (memberUid == request.auth.uid && 
           incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'reminderSettings', 'lastReadAt']) &&
           incoming().status == existing().status && // Cannot self-approve
           incoming().role == existing().role      // Cannot self-promote
          )
        ) && isValidMember(incoming());

        allow delete: if isGroupAdmin(groupId) || (isVerified() && memberUid == request.auth.uid);
      }

      // Logs Subcollection
      match /logs/{logId} {
        allow get: if isMember(groupId) && isValidId(logId);
        allow list: if isMember(groupId); // Pillar 8: groupId is constant for query

        allow create: if isApprovedMember(groupId) && isValidLog(incoming());
        
        allow update: if isVerified() && (
          // Action: Confirm Reading
          (incoming().diff(existing()).affectedKeys().hasOnly(['confirmedByUid', 'confirmerName']) &&
           incoming().confirmedByUid == request.auth.uid &&
           existing().confirmedByUid == null) // Cannot overwrite existing confirmation
        );
        
        allow delete: if isGroupAdmin(groupId) || (isVerified() && existing().memberUid == request.auth.uid);

        // Comments Subcollection
        match /comments/{commentId} {
          allow read: if isMember(groupId) && (isValidId(commentId) || true); // true for list
          allow create: if isApprovedMember(groupId) && isValidComment(incoming());
          allow delete: if isGroupAdmin(groupId) || (isVerified() && existing().memberUid == request.auth.uid);
        }
      }
    }
  }
}
